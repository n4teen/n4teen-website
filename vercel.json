{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.n4teen.com"
        }
      ],
      "destination": "https://n4teen.com/:path*",
      "permanent": true
    },
    {
      "source": "/services",
      "destination": "/funding-readiness",
      "permanent": true
    },
    {
      "source": "/apply",
      "destination": "https://apply.n4teen.com/path-8633",
      "permanent": true
    },
    {
      "source": "/business-credit-preparation",
      "destination": "/funding-readiness",
      "permanent": true
    },
    {
      "source": "/funding-readiness-review",
      "destination": "/funding-readiness",
      "permanent": true
    },
    {
      "source": "/readiness-review",
      "destination": "/readiness-framework",
      "permanent": true
    },
    {
      "source": "/insights",
      "destination": "/readiness-framework",
      "permanent": true
    },
    {
      "source": "/insights/:slug*",
      "destination": "/readiness-framework",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(ico|svg|woff2|jpg|jpeg|png|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    }
  ]
}